{
  "name": "finta",
  "version": "1.0.0",
  "description": "FINancial Tracking & Analysis - Monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "cf-typegen": "turbo run cf-typegen",
    "check": "turbo run check",
    "dev": "turbo run dev",
    "deploy": "turbo run deploy",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "^3.2.4",
    "turbo": "^2.8.3",
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "supportedArchitectures": {
      "os": ["darwin", "linux"],
      "cpu": ["x64", "arm64"]
    }
  },
  "dependencies": {
    "@types/node": "^25.4.0",
    "zod": "^4.3.6"
  }
}
