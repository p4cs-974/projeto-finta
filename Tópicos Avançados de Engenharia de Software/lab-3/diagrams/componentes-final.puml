@startuml
title FINTA - Diagrama de Componentes (Pacote Final)
left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle

actor "Usuário" as U
cloud "API Mercado Financeiro" as EXT_MKT
cloud "API FIPE" as EXT_FIPE

interface IPriceQueryService
interface IFipeQueryService
interface IRegistrationService
interface IUserLibraryService
interface IMarketDataGateway
interface IFipeGateway
interface IAuthRepository

component "Frontend Web App" as FE
component "Market Data Adapter" as MKTAD
component "FIPE Adapter" as FIPEAD

rectangle "Backend API <<component>>" as BE {
  component "Auth Module" as AUTH
}

U --> FE : usa

FE ..> IPriceQueryService : consome
FE ..> IFipeQueryService : consome
FE ..> IRegistrationService : consome
FE ..> IUserLibraryService : usa

IPriceQueryService - BE : fornece
IFipeQueryService - BE : fornece
IRegistrationService - BE : fornece
IUserLibraryService - FE : implementa\n(localStorage)

BE ..> IMarketDataGateway : requer
BE ..> IFipeGateway : requer

IMarketDataGateway - MKTAD : implementa
IFipeGateway - FIPEAD : implementa

MKTAD --> EXT_MKT : consulta
FIPEAD --> EXT_FIPE : consulta

AUTH ..> IAuthRepository : usa
IAuthRepository - AUTH : implementa

note right of AUTH
  Módulo interno ao Backend API.
  Não representa componente de
  implantação separado.
end note

@enduml
