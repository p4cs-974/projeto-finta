@startuml casos-de-uso-finta
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor white
  BorderColor #444444
}
skinparam actorStyle awesome

title FINTA - Casos de Uso Consolidados

actor "Usuario" as User
actor "API Financeira" as FinanceApi
actor "API Cripto" as CryptoApi
actor "API Selic / Bacen" as SelicApi
actor "API Taxas de\nFinanciamento" as FundingApi

rectangle "Sistema FINTA" {
  package "Acesso" {
    usecase "UC3 - Realizar\ncadastro" as UC3
    usecase "UC4 - Realizar\nlogin" as UC4
  }

  package "Mercado e favoritos" {
    usecase "UC1 - Visualizar\ndashboard financeiro" as UC1
    usecase "UC2 - Visualizar detalhes\nde indicadores/ativos" as UC2
    usecase "UC5 - Adicionar\nfavoritos" as UC5
    usecase "UC6 - Editar\nfavoritos" as UC6
    usecase "UC7 - Remover\nfavoritos" as UC7
    usecase "UC8 - Consultar cotacoes\nem tempo real" as UC8
  }

  package "Macroeconomia e credito" {
    usecase "UC9 - Visualizar taxa\nSelic atualizada" as UC9
    usecase "UC10 - Listar taxas de\nfinanciamento" as UC10
    usecase "UC11 - Simular\nfinanciamento" as UC11
    usecase "UC12 - Visualizar\nsimulacoes salvas" as UC12
    usecase "UC13 - Remover\nsimulacao salva" as UC13
  }
}

User -- UC1
User -- UC2
User -- UC3
User -- UC4
User -- UC5
User -- UC6
User -- UC7
User -- UC8
User -- UC9
User -- UC10
User -- UC11
User -- UC12
User -- UC13

UC1 .> UC8 : <<include>>
UC1 .> UC9 : <<include>>
UC2 .> UC8 : <<include>>
UC5 .> UC8 : <<include>>
UC6 .> UC8 : <<include>>
UC11 .> UC10 : <<include>>

FinanceApi -- UC8
CryptoApi -- UC8
SelicApi -- UC9
FundingApi -- UC10
FundingApi -- UC11

@enduml
