@startuml casos-de-uso-finta
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam dpi 180
skinparam backgroundColor #FCFCFA
skinparam defaultFontName Arial
skinparam defaultFontSize 16
skinparam titleFontSize 24
skinparam titleFontColor #16324F
skinparam packageTitleFontSize 18
skinparam packageTitleFontColor #16324F
skinparam packageBorderColor #7A8A99
skinparam packageBackgroundColor #F2F5F7
skinparam rectangleBorderColor #7A8A99
skinparam rectangleBackgroundColor #F8FAFB
skinparam noteFontSize 14
skinparam noteBackgroundColor #FFF5D6
skinparam noteBorderColor #C88A12
skinparam ArrowColor #425466
skinparam ArrowThickness 1.3
skinparam usecase {
  FontSize 16
  FontColor #102A43
  BackgroundColor #FFFFFF
  BorderColor #486581
  BorderThickness 1.2
}
skinparam actor {
  FontSize 16
  FontColor #102A43
  BorderColor #486581
}

title FINTA - Casos de Uso Implementados

actor "Usuario" as User
actor "Brapi" as Brapi
actor "CoinCap" as CoinCap

rectangle "Sistema FINTA" {
  package "Acesso" {
    usecase "UC3 - Realizar\ncadastro" as UC3
    usecase "UC4 - Realizar\nlogin" as UC4
    usecase "UC5 - Realizar\nlogout" as UC5
  }

  package "Consulta de ativos" {
    usecase "UC6 - Visualizar detalhes\nde ativos" as UC6
    usecase "UC8 - Consultar cotacoes\nem tempo real" as UC8
    usecase "UC9 - Visualizar historico\nrecente de ativos" as UC9
  }
}

User -- UC3
User -- UC4
User -- UC5
User -- UC6
User -- UC8
User -- UC9

UC6 .> UC8 : <<include>>

Brapi -- UC8
CoinCap -- UC8

note bottom of UC9
Exibido na busca autenticada quando
nao ha ticker informado.
end note

note bottom of UC6
Ao abrir o detalhe do ativo, o app
registra a selecao recente do usuario.
end note

@enduml
