@startuml diagrama-final-consolidado
top to bottom direction
skinparam shadowing false
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam dpi 180
skinparam backgroundColor #FCFCFA
skinparam defaultFontName Arial
skinparam defaultFontSize 15
skinparam titleFontSize 24
skinparam titleFontColor #16324F
skinparam packageTitleFontSize 18
skinparam packageTitleFontColor #16324F
skinparam packageBorderColor #7A8A99
skinparam packageBackgroundColor #F5F7F9
skinparam component {
  FontSize 15
  FontColor #102A43
  BorderColor #486581
  BorderThickness 1.2
  BackgroundColor #FFFFFF
}
skinparam database {
  FontSize 15
  FontColor #102A43
  BorderColor #7C5E10
  BackgroundColor #FFF7DB
}
skinparam cloud {
  FontSize 15
  FontColor #102A43
  BorderColor #0F6D7A
  BackgroundColor #E9FBFF
}
skinparam actor {
  FontSize 16
  FontColor #102A43
  BorderColor #486581
}
skinparam note {
  FontSize 14
  FontColor #102A43
  BorderColor #A0AEC0
  BackgroundColor #F8FAFB
}
skinparam ArrowColor #425466
skinparam ArrowThickness 1.3
skinparam nodesep 70
skinparam ranksep 95

title FINTA - Componentes Implementados

actor "Usuario" as User

package "Camada 1 - Interacao" {
  component "frontend-cloudflare\nNext.js Web App + BFF" as Front #EAF2FF
}

package "Camada 2 - API / Composicao" {
  component "backend-cloudflare\nCloudflare Worker API" as Back #EAF2FF
}

package "Camada 3 - Servicos de dominio" {
  component "@finta/identity-access\nRegistrationService\nAuthenticationService" as Identity #EEF8EE
  component "@finta/price-query\nPriceQueryService" as PriceQuery #EEF8EE
  component "@finta/user-assets\nRecentAssetSelectionService" as UserAssets #EEF8EE
}

package "Camada 4 - Adapters" {
  component "D1UserRepository" as D1UserRepo #FFFDF7
  component "PasswordHasherAdapter" as PasswordHasher #FFFDF7
  component "JwtTokenService" as JwtToken #FFFDF7
  component "CloudflareKvQuoteSnapshotStore" as QuoteStore #FFFDF7
  component "createMarketDataGateway\nBrapiMarketDataGateway\nCoinCapMarketDataGateway" as MarketGateway #FFFDF7
  component "D1UserAssetRepository" as D1UserAssetRepo #FFFDF7
}

package "Camada 5 - Infraestrutura externa" {
  database "Cloudflare D1\nusers + recent_asset_selections" as D1
  database "Cloudflare KV\nASSET_CACHE" as KV
  cloud "Brapi" as Brapi
  cloud "CoinCap" as CoinCap
}

package "Base compartilhada" {
  component "@finta/shared-kernel\ncontracts + errors" as SharedKernel #F4EEFF
}

User --> Front : usa a UI
Front --> Back : /api/* + fetch server-side

Back --> Identity : auth
Back --> PriceQuery : quotes
Back --> UserAssets : recentes

Identity --> D1UserRepo : IUserRepository
Identity --> PasswordHasher : IPasswordHasher
Identity --> JwtToken : ITokenService

PriceQuery --> QuoteStore : IQuoteSnapshotStore
PriceQuery --> MarketGateway : IMarketDataGateway

UserAssets --> D1UserAssetRepo : IUserAssetRepository

D1UserRepo --> D1
D1UserAssetRepo --> D1
QuoteStore --> KV
MarketGateway --> Brapi
MarketGateway --> CoinCap

Identity ..> SharedKernel
PriceQuery ..> SharedKernel
UserAssets ..> SharedKernel
Back ..> SharedKernel
Front ..> SharedKernel

Identity -[hidden]right-> PriceQuery
PriceQuery -[hidden]right-> UserAssets

D1UserRepo -[hidden]right-> PasswordHasher
PasswordHasher -[hidden]right-> JwtToken
JwtToken -[hidden]right-> QuoteStore
QuoteStore -[hidden]right-> MarketGateway
MarketGateway -[hidden]right-> D1UserAssetRepo

D1 -[hidden]right-> KV
KV -[hidden]right-> Brapi
Brapi -[hidden]right-> CoinCap

note right of Front
Entrada do usuario e BFF.
end note

note right of Back
Compoe os servicos e expone as rotas HTTP.
end note

note right of SharedKernel
Biblioteca compartilhada de tipos,
contratos e erros.
end note

@enduml
