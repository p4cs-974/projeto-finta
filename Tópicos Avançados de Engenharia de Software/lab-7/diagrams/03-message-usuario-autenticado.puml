@startuml 03-message-usuario-autenticado
skinparam shadowing false
skinparam dpi 180
skinparam backgroundColor #FCFCFA
skinparam defaultFontName Arial
skinparam defaultFontSize 14
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #486581
  FontColor #102A43
}
skinparam note {
  BackgroundColor #F8FAFB
  BorderColor #A0AEC0
  FontColor #102A43
}

title UsuarioAutenticado

class UsuarioAutenticado <<response>> {
  + usuarioId: UUID
  + nome: string
  + email: string
  + expiresAt: datetime
}

note right of UsuarioAutenticado
Mensagem de resposta da operacao
validarAutenticacao.
end note

@enduml
