@startuml InterfaceIntegracaoProvedoresMercado
!pragma layout smetana
title Interface - Serviço de Integração com Provedores de Mercado

skinparam classAttributeIconSize 0
skinparam classBackgroundColor #F8F9FA
skinparam classBorderColor #2C3E50
skinparam stereotypeCBackgroundColor #E8F4FD

interface "IIntegracaoProvedoresMercado" as ISvc <<Service Interface>> {
  + consultarCotacaoExterna(req: ConsultarCotacaoExternaRequest): ConsultarCotacaoExternaResponse
}

class ConsultarCotacaoExternaRequest <<DTO / Entrada>> {
  + tipoAtivo : TipoAtivo  {enum: ACAO | CRIPTO}
  + simbolo  : string      {normalizado, uppercase, 1..15 chars}
}

class ConsultarCotacaoExternaResponse <<DTO / Saída>> {
  + cotacao        : CotacaoNormalizada
  + provedorOrigem : string
  + timestamp      : datetime (ISO-8601, UTC)
}

class CotacaoNormalizada <<DTO>> {
  + tipoAtivo     : TipoAtivo
  + simbolo       : string
  + preco         : decimal(18,8)
  + moeda         : string  {ISO-4217, ex: BRL, USD}
  + variacaoDia   : decimal(8,4)  {percentual}
  + volume        : decimal(20,2)
  + dataReferencia: datetime (ISO-8601, UTC)
}

class ErroIntegracao <<DTO / Erro>> {
  + codigo  : int       {404, 502}
  + chave   : string    {ASSET_NOT_FOUND | EXTERNAL_SERVICE_ERROR}
  + mensagem: string
  + detalhe : string    {opcional - corpo do provedor}
}

enum TipoAtivo {
  ACAO
  CRIPTO
}

ISvc ..> ConsultarCotacaoExternaRequest  : consome
ISvc ..> ConsultarCotacaoExternaResponse : produz
ISvc ..> ErroIntegracao                  : lança
ConsultarCotacaoExternaRequest  --> TipoAtivo
ConsultarCotacaoExternaResponse --> CotacaoNormalizada
CotacaoNormalizada --> TipoAtivo

note right of ISvc
  **Operação:** consultarCotacaoExterna
  **Entrada:** tipoAtivo, simbolo (validados)
  **Saída:** cotação normalizada + origem + timestamp
  **Erros:** 404 ASSET_NOT_FOUND, 502 EXTERNAL_SERVICE_ERROR
end note

@enduml
